<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackground" Color="#1C1C1E"/>
    <SolidColorBrush x:Key="PrimaryText" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#AEAEB2"/>
    <SolidColorBrush x:Key="SurfaceColor" Color="#2C2C2E"/>
    <SolidColorBrush x:Key="SurfaceHover" Color="#3A3A3C"/>
    <SolidColorBrush x:Key="CardBackground" Color="#2C2C2E"/>
    <SolidColorBrush x:Key="AccentBlue" Color="#0A84FF"/>
    <SolidColorBrush x:Key="AccentGreen" Color="#30D158"/>
    <SolidColorBrush x:Key="PomodoroRed" Color="#8B3A3A"/>
    <SolidColorBrush x:Key="SegIndicatorBg" Color="#3A3A3C"/>
    <SolidColorBrush x:Key="ToggleTrackOff" Color="#39393D"/>
    <SolidColorBrush x:Key="ToggleThumb" Color="White"/>
    <SolidColorBrush x:Key="DividerColor" Color="#38383A"/>
    <SolidColorBrush x:Key="PowerIconStroke" Color="#AEAEB2"/>
    <SolidColorBrush x:Key="PowerIconFill" Color="#2C2C2E"/>
    <SolidColorBrush x:Key="PowerIconStrokeOutline" Color="#3A3A3C"/>

    <Color x:Key="WindowBackgroundColor">#1C1C1E</Color>
    <Color x:Key="PomodoroRedColor">#8B3A3A</Color>
    <Color x:Key="PrimaryTextColor">#FFFFFF</Color>
    <Color x:Key="AccentBlueColor">#0A84FF</Color>
    <Color x:Key="PowerIconFillColor">#2C2C2E</Color>
    <Color x:Key="PowerIconStrokeColor">#AEAEB2</Color>

</ResourceDictionary>
