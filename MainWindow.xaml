<Window x:Class="CaffeineWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CaffeineWin.Controls"
        Title="Caffeine"
        Width="380" Height="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <CubicEase x:Key="BubbleEase" EasingMode="EaseOut"/>
        <QuadraticEase x:Key="SoftEase" EasingMode="EaseInOut"/>

        <!-- Toggle switch (adapts to theme) -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="Track" Width="51" Height="31"
                                    CornerRadius="15.5" Background="{DynamicResource ToggleTrackOff}" Cursor="Hand"/>
                            <Border x:Name="Thumb" Width="27" Height="27"
                                    CornerRadius="13.5" Background="{DynamicResource ToggleThumb}"
                                    HorizontalAlignment="Left" Margin="2,0,0,0" Cursor="Hand">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.2"/>
                                </Border.Effect>
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentGreen}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="20" Duration="0:0:0.25"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.25"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pill button — indicator handles highlight bg -->
        <Style x:Key="PillButtonStyle" TargetType="RadioButton">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Pill" Padding="14,8" CornerRadius="16"
                                Background="Transparent" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="1.05" Duration="0:0:0.15"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1.05" Duration="0:0:0.15"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="1" Duration="0:0:0.2"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1" Duration="0:0:0.2"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>

        <!-- Dark pill button (pomodoro, on red bg) -->
        <Style x:Key="DarkPillStyle" TargetType="RadioButton">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Pill" Padding="12,7" CornerRadius="14"
                                Background="#26FFFFFF" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="#CCFFFFFF"/>
                                <Setter Property="Foreground" Value="#AF4949"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="1.05" Duration="0:0:0.15"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1.05" Duration="0:0:0.15"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="1" Duration="0:0:0.2"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1" Duration="0:0:0.2"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Segmented control (transparent bg, indicator does the work) -->
        <Style x:Key="SegmentStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Padding="14,6" CornerRadius="8" Background="Transparent" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Action button (pomodoro) -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="22,11" CornerRadius="20" Background="White" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="1.06" Duration="0:0:0.15"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1.06" Duration="0:0:0.15"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="1" Duration="0:0:0.2"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1" Duration="0:0:0.2"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="0.94" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="0.94" Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#AF4949"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="16,10" CornerRadius="18" Background="#26FFFFFF" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="1.06" Duration="0:0:0.15"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1.06" Duration="0:0:0.15"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="1" Duration="0:0:0.2"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1" Duration="0:0:0.2"
                                                             EasingFunction="{StaticResource BubbleEase}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Margin="16">
        <Border.Background>
            <SolidColorBrush x:Name="WindowBg" Color="{DynamicResource WindowBackgroundColor}"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect ShadowDepth="2" BlurRadius="24" Opacity="0.15" Color="#000000"/>
        </Border.Effect>
        <Border CornerRadius="12" ClipToBounds="True">
            <Border.Background>
                <SolidColorBrush x:Name="InnerBg" Color="{DynamicResource WindowBackgroundColor}"/>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0" Padding="20,14,20,8" MouseLeftButtonDown="TitleBar_MouseDown">
                    <Grid>
                        <TextBlock x:Name="TitleText" Text="Caffeine"
                                   FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Click="SettingsButton_Click" Cursor="Hand" Margin="0,0,8,0"
                                    RenderTransformOrigin="0.5,0.5">
                                <Button.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Button.RenderTransform>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="GearBorder" Width="28" Height="28"
                                                CornerRadius="14" Background="{DynamicResource SurfaceColor}">
                                            <TextBlock Text="⚙" FontSize="14" Foreground="{DynamicResource SecondaryText}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="GearBorder" Property="Background" Value="{DynamicResource SurfaceHover}"/>
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.1" Duration="0:0:0.15" EasingFunction="{StaticResource BubbleEase}"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.1" Duration="0:0:0.15" EasingFunction="{StaticResource BubbleEase}"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.2" EasingFunction="{StaticResource BubbleEase}"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.2" EasingFunction="{StaticResource BubbleEase}"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Click="CloseButton_Click" Cursor="Hand" RenderTransformOrigin="0.5,0.5">
                                <Button.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Button.RenderTransform>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CloseBorder" Width="28" Height="28"
                                                CornerRadius="14" Background="{DynamicResource SurfaceColor}">
                                            <TextBlock Text="✕" FontSize="12" Foreground="{DynamicResource SecondaryText}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CloseBorder" Property="Background" Value="{DynamicResource SurfaceHover}"/>
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.1" Duration="0:0:0.15" EasingFunction="{StaticResource BubbleEase}"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.1" Duration="0:0:0.15" EasingFunction="{StaticResource BubbleEase}"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.2" EasingFunction="{StaticResource BubbleEase}"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.2" EasingFunction="{StaticResource BubbleEase}"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Segmented control with gooey indicator -->
                <Border Grid.Row="1" Margin="0,0,0,12" HorizontalAlignment="Center">
                    <Border Background="{DynamicResource SurfaceColor}" CornerRadius="10" Padding="3">
                        <Grid>
                            <Border x:Name="SegIndicator" Background="{DynamicResource SegIndicatorBg}" CornerRadius="8"
                                    HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="75">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.12"/>
                                </Border.Effect>
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="SegIndicatorX" X="0"/>
                                </Border.RenderTransform>
                            </Border>
                            <StackPanel x:Name="SegPanel" Orientation="Horizontal">
                                <RadioButton x:Name="TabCaffeine" Content="Caffeine" GroupName="Tabs" IsChecked="True"
                                             Style="{StaticResource SegmentStyle}" Checked="Tab_Changed" Click="Tab_Clicked"/>
                                <RadioButton x:Name="TabPomodoro" Content="Pomodoro" GroupName="Tabs"
                                             Style="{StaticResource SegmentStyle}" Checked="Tab_Changed" Click="Tab_Clicked"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Border>

                <!-- ========== CAFFEINE TAB ========== -->
                <Border x:Name="CaffeinePanel" Grid.Row="2" Opacity="1" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                    <ScrollViewer VerticalScrollBarVisibility="Hidden">
                        <StackPanel Margin="24,0,24,24" HorizontalAlignment="Center">
                            <StackPanel HorizontalAlignment="Center" Margin="0,24,0,24" MinWidth="200">
                                <Button x:Name="ToggleButton" Click="ToggleButton_Click" Cursor="Hand"
                                        HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <Button.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Button.RenderTransform>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid Width="120" Height="120">
                                                <Ellipse x:Name="ToggleCircle" Fill="{DynamicResource PowerIconFill}"
                                                         Stroke="{DynamicResource PowerIconStrokeOutline}" StrokeThickness="1"/>
                                                <Path x:Name="PowerIcon"
                                                      Data="M20,4 L20,12 M20,24 A12,12 0 1,1 20,4.1"
                                                      Stroke="{DynamicResource PowerIconStroke}" StrokeThickness="3"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      Stretch="Uniform" Width="42" Height="42"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.08" Duration="0:0:0.2" EasingFunction="{StaticResource BubbleEase}"/>
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.08" Duration="0:0:0.2" EasingFunction="{StaticResource BubbleEase}"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.25" EasingFunction="{StaticResource BubbleEase}"/>
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.25" EasingFunction="{StaticResource BubbleEase}"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="0.92" Duration="0:0:0.08"/>
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="0.92" Duration="0:0:0.08"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <local:ScrollingTextBlock x:Name="StatusText" Text="Inactive"
                                    TextFontSize="22" TextFontWeight="SemiBold"
                                    TextForeground="{DynamicResource PrimaryText}" TextFontFamily="Segoe UI"
                                    HorizontalAlignment="Center" Margin="0,20,0,6" AnimationMilliseconds="200"/>
                                <local:ScrollingTextBlock x:Name="ElapsedText" Text="Screen will sleep normally"
                                    TextFontSize="13" TextForeground="{DynamicResource SecondaryText}" TextFontFamily="Segoe UI"
                                    HorizontalAlignment="Center" AnimationMilliseconds="150"/>
                                <TextBlock x:Name="ModeIndicator" Text="Mode: Standard"
                                           FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource SecondaryText}"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>

                            <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="14,12" Margin="0,16,0,16" HorizontalAlignment="Center" MinWidth="260">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Stay Green" FontFamily="Segoe UI" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryText}"/>
                                        <TextBlock Text="Jiggle mouse to stay active" FontFamily="Segoe UI" FontSize="10" Foreground="{DynamicResource SecondaryText}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="CaffeineStayGreenToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center"
                                              Checked="CaffeineStayGreen_Changed" Unchecked="CaffeineStayGreen_Changed"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="AUTO-OFF" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <Grid HorizontalAlignment="Center">
                                <Border x:Name="TimerIndicator" Background="{DynamicResource AccentBlue}" CornerRadius="16"
                                        HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="50">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="TimerIndicatorX" X="0"/>
                                    </Border.RenderTransform>
                                </Border>
                                <StackPanel x:Name="TimerPanel" Orientation="Horizontal">
                                    <RadioButton x:Name="TimerOff" Content="Off" Style="{StaticResource PillButtonStyle}" IsChecked="True" Checked="Timer_Checked" Tag="0"/>
                                    <RadioButton x:Name="Timer15" Content="15m" Style="{StaticResource PillButtonStyle}" Checked="Timer_Checked" Tag="15"/>
                                    <RadioButton x:Name="Timer30" Content="30m" Style="{StaticResource PillButtonStyle}" Checked="Timer_Checked" Tag="30"/>
                                    <RadioButton x:Name="Timer60" Content="1h" Style="{StaticResource PillButtonStyle}" Checked="Timer_Checked" Tag="60"/>
                                    <RadioButton x:Name="Timer120" Content="2h" Style="{StaticResource PillButtonStyle}" Checked="Timer_Checked" Tag="120"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ========== POMODORO TAB ========== -->
                <Border x:Name="PomodoroPanel" Grid.Row="2" Opacity="0" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                    <ScrollViewer VerticalScrollBarVisibility="Hidden">
                        <StackPanel Margin="24,16,24,24" HorizontalAlignment="Center">
                            <Grid x:Name="TimerRingContainer" HorizontalAlignment="Center" Margin="0,8,0,8" Width="180" Height="180"
                                  RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform><ScaleTransform x:Name="TimerRingScale" ScaleX="1" ScaleY="1"/></Grid.RenderTransform>
                                <Ellipse Stroke="#26FFFFFF" StrokeThickness="5" Width="180" Height="180"/>
                                <Canvas Width="180" Height="180">
                                    <Path x:Name="ProgressArc" Stroke="White" StrokeThickness="5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <local:ScrollingTextBlock x:Name="PomTimeDisplay" Text="25:00"
                                        TextFontSize="44" TextFontWeight="Light"
                                        TextForeground="White" TextFontFamily="Segoe UI"
                                        HorizontalAlignment="Center" AnimationMilliseconds="180"/>
                                    <local:ScrollingTextBlock x:Name="PomPhaseText" Text="Work"
                                        TextFontSize="13" TextFontWeight="Medium"
                                        TextForeground="#B3FFFFFF" TextFontFamily="Segoe UI"
                                        HorizontalAlignment="Center" AnimationMilliseconds="200"/>
                                </StackPanel>
                            </Grid>
                            <local:ScrollingTextBlock x:Name="PomCycleText" Text="Cycle 1 of 4"
                                TextFontSize="12" TextForeground="#B3FFFFFF" TextFontFamily="Segoe UI"
                                HorizontalAlignment="Center" Margin="0,4,0,18" AnimationMilliseconds="200"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="PomStartPauseButton" Content="Start"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="PomStartPause_Click" Margin="0,0,8,0"/>
                                <Button Content="Reset" Style="{StaticResource SecondaryButtonStyle}"
                                        Click="PomReset_Click" Margin="0,0,8,0"/>
                                <Button Content="Skip" Style="{StaticResource SecondaryButtonStyle}"
                                        Click="PomSkip_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ========== SETTINGS PANEL ========== -->
                <Border x:Name="SettingsPanel" Grid.Row="2" Opacity="0" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                    <ScrollViewer x:Name="SettingsScroller" VerticalScrollBarVisibility="Hidden"
                                  PreviewMouseWheel="SmoothScroll_MouseWheel">
                        <StackPanel Margin="24,8,24,24">

                            <TextBlock Text="Settings" FontFamily="Segoe UI" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,20"/>

                            <!-- APPEARANCE -->
                            <TextBlock Text="APPEARANCE" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,10"/>
                            <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Theme" FontFamily="Segoe UI" FontSize="13" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Border x:Name="ThemeIndicator" Background="{DynamicResource AccentBlue}" CornerRadius="16"
                                                HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="50">
                                            <Border.RenderTransform><TranslateTransform x:Name="ThemeIndicatorX" X="0"/></Border.RenderTransform>
                                        </Border>
                                        <StackPanel x:Name="ThemePanel" Orientation="Horizontal">
                                            <RadioButton x:Name="ThemeSystem" Content="System" GroupName="Theme" IsChecked="True" Style="{StaticResource PillButtonStyle}" Checked="Theme_Checked" Tag="System"/>
                                            <RadioButton x:Name="ThemeLight" Content="Light" GroupName="Theme" Style="{StaticResource PillButtonStyle}" Checked="Theme_Checked" Tag="Light"/>
                                            <RadioButton x:Name="ThemeDark" Content="Dark" GroupName="Theme" Style="{StaticResource PillButtonStyle}" Checked="Theme_Checked" Tag="Dark"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- GENERAL -->
                            <TextBlock Text="GENERAL" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,10"/>
                            <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Start with Windows" FontFamily="Segoe UI" FontSize="14" Foreground="{DynamicResource PrimaryText}"/>
                                        <TextBlock Text="Launch automatically on login" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="AutoStartToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center"
                                              Checked="AutoStart_Changed" Unchecked="AutoStart_Changed"/>
                                </Grid>
                            </Border>

                            <!-- CAFFEINE -->
                            <TextBlock Text="CAFFEINE" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,10"/>
                            <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Stay Green mode" FontFamily="Segoe UI" FontSize="14" Foreground="{DynamicResource PrimaryText}"/>
                                        <TextBlock Text="Jiggle mouse instead of blocking sleep" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="StayGreenToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center"
                                              Checked="StayGreen_Changed" Unchecked="StayGreen_Changed"/>
                                </Grid>
                            </Border>

                            <!-- POMODORO -->
                            <TextBlock Text="POMODORO" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,10"/>
                            <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Work duration" FontFamily="Segoe UI" FontSize="13" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,8"/>
                                    <Grid Margin="0,0,0,14">
                                        <Border x:Name="WorkIndicator" Background="{DynamicResource AccentBlue}" CornerRadius="16" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="50">
                                            <Border.RenderTransform><TranslateTransform x:Name="WorkIndicatorX" X="0"/></Border.RenderTransform>
                                        </Border>
                                        <StackPanel x:Name="WorkPanel" Orientation="Horizontal">
                                            <RadioButton x:Name="PomWork15" Content="15m" GroupName="PomWork" Style="{StaticResource PillButtonStyle}" Checked="PomWorkDuration_Checked" Tag="15"/>
                                            <RadioButton x:Name="PomWork25" Content="25m" GroupName="PomWork" IsChecked="True" Style="{StaticResource PillButtonStyle}" Checked="PomWorkDuration_Checked" Tag="25"/>
                                            <RadioButton x:Name="PomWork45" Content="45m" GroupName="PomWork" Style="{StaticResource PillButtonStyle}" Checked="PomWorkDuration_Checked" Tag="45"/>
                                            <RadioButton x:Name="PomWorkCustomRadio" Content="Custom" GroupName="PomWork" Style="{StaticResource PillButtonStyle}" Checked="PomWorkCustom_Checked"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBox x:Name="PomWorkCustomInput" Visibility="Collapsed" Width="80" HorizontalAlignment="Left" FontFamily="Segoe UI" FontSize="13" Padding="8,6" Margin="0,0,0,14" Text="25" LostFocus="PomWorkCustomInput_LostFocus"/>

                                    <TextBlock Text="Short break" FontFamily="Segoe UI" FontSize="13" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,8"/>
                                    <Grid Margin="0,0,0,14">
                                        <Border x:Name="ShortIndicator" Background="{DynamicResource AccentBlue}" CornerRadius="16" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="50">
                                            <Border.RenderTransform><TranslateTransform x:Name="ShortIndicatorX" X="0"/></Border.RenderTransform>
                                        </Border>
                                        <StackPanel x:Name="ShortPanel" Orientation="Horizontal">
                                            <RadioButton x:Name="PomShort5" Content="5m" GroupName="PomShort" IsChecked="True" Style="{StaticResource PillButtonStyle}" Checked="PomShortBreak_Checked" Tag="5"/>
                                            <RadioButton x:Name="PomShort10" Content="10m" GroupName="PomShort" Style="{StaticResource PillButtonStyle}" Checked="PomShortBreak_Checked" Tag="10"/>
                                            <RadioButton x:Name="PomShortCustomRadio" Content="Custom" GroupName="PomShort" Style="{StaticResource PillButtonStyle}" Checked="PomShortCustom_Checked"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBox x:Name="PomShortCustomInput" Visibility="Collapsed" Width="80" HorizontalAlignment="Left" FontFamily="Segoe UI" FontSize="13" Padding="8,6" Margin="0,0,0,14" Text="5" LostFocus="PomShortCustomInput_LostFocus"/>

                                    <TextBlock Text="Long break" FontFamily="Segoe UI" FontSize="13" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,8"/>
                                    <Grid Margin="0,0,0,14">
                                        <Border x:Name="LongIndicator" Background="{DynamicResource AccentBlue}" CornerRadius="16" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="50">
                                            <Border.RenderTransform><TranslateTransform x:Name="LongIndicatorX" X="0"/></Border.RenderTransform>
                                        </Border>
                                        <StackPanel x:Name="LongPanel" Orientation="Horizontal">
                                            <RadioButton x:Name="PomLong15" Content="15m" GroupName="PomLong" IsChecked="True" Style="{StaticResource PillButtonStyle}" Checked="PomLongBreak_Checked" Tag="15"/>
                                            <RadioButton x:Name="PomLong20" Content="20m" GroupName="PomLong" Style="{StaticResource PillButtonStyle}" Checked="PomLongBreak_Checked" Tag="20"/>
                                            <RadioButton x:Name="PomLong30" Content="30m" GroupName="PomLong" Style="{StaticResource PillButtonStyle}" Checked="PomLongBreak_Checked" Tag="30"/>
                                            <RadioButton x:Name="PomLongCustomRadio" Content="Custom" GroupName="PomLong" Style="{StaticResource PillButtonStyle}" Checked="PomLongCustom_Checked"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBox x:Name="PomLongCustomInput" Visibility="Collapsed" Width="80" HorizontalAlignment="Left" FontFamily="Segoe UI" FontSize="13" Padding="8,6" Margin="0,0,0,14" Text="15" LostFocus="PomLongCustomInput_LostFocus"/>

                                    <TextBlock Text="Cycles before long break" FontFamily="Segoe UI" FontSize="13" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,8"/>
                                    <Grid Margin="0,0,0,14">
                                        <Border x:Name="CyclesIndicator" Background="{DynamicResource AccentBlue}" CornerRadius="16" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="40">
                                            <Border.RenderTransform><TranslateTransform x:Name="CyclesIndicatorX" X="0"/></Border.RenderTransform>
                                        </Border>
                                        <StackPanel x:Name="CyclesPanel" Orientation="Horizontal">
                                            <RadioButton x:Name="PomCycles3" Content="3" GroupName="PomCycles" Style="{StaticResource PillButtonStyle}" Checked="PomCycles_Checked" Tag="3"/>
                                            <RadioButton x:Name="PomCycles4" Content="4" GroupName="PomCycles" IsChecked="True" Style="{StaticResource PillButtonStyle}" Checked="PomCycles_Checked" Tag="4"/>
                                            <RadioButton x:Name="PomCycles5" Content="5" GroupName="PomCycles" Style="{StaticResource PillButtonStyle}" Checked="PomCycles_Checked" Tag="5"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,0,0,14"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Keep screen awake" FontFamily="Segoe UI" FontSize="14" Foreground="{DynamicResource PrimaryText}"/>
                                            <TextBlock Text="During work sessions" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="PomKeepAwakeToggle" Grid.Column="1"
                                                  Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" IsChecked="True"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- RESET -->
                            <Button Click="ResetDefaults_Click" Cursor="Hand" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ResetBorder" Padding="18,10" CornerRadius="18" Background="{DynamicResource SurfaceColor}">
                                            <TextBlock Text="Reset to Defaults" FontFamily="Segoe UI" FontSize="13"
                                                       FontWeight="Medium" Foreground="{DynamicResource SecondaryText}"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ResetBorder" Property="Background" Value="{DynamicResource SurfaceHover}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>
